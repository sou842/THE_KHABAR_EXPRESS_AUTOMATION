{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["chrome", "node"],
    "baseUrl": ".",
    "paths": {
      "@src/*": ["./src/*"],
      "@extension/shared": ["../packages/shared/lib/index.ts"],
      "@extension/storage": ["../packages/storage/lib/index.ts"]
    }
  },
  "include": ["src/**/*", "manifest.js"]
}
