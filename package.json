{
  "name": "mini-bot-enhanced",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean:bundle": "rimraf dist && turbo clean:bundle",
    "clean:node_modules": "pnpx rimraf node_modules && pnpx turbo clean:node_modules",
    "clean:turbo": "rimraf .turbo && turbo clean:turbo",
    "clean": "pnpm clean:bundle && pnpm clean:turbo && pnpm clean:node_modules",
    "clean:install": "pnpm clean:node_modules && pnpm install --frozen-lockfile",
    "build": "pnpm clean:bundle && turbo ready && turbo build",
    "dev": "turbo ready && concurrently \"node scripts/watch.mjs\" \"cross-env __DEV__=true turbo watch dev --concurrency 20\"",
    "type-check": "turbo type-check",
    "lint": "turbo lint --continue -- --fix",
    "prettier": "turbo prettier --continue"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.330",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.1",
    "eslint": "8.57.0",
    "lucide-react": "^0.575.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.6.3",
    "turbo": "^2.5.3",
    "typescript": "5.5.4",
    "vite": "^6.4.1",
    "ws": "^8.19.0"
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=22.12.0"
  }
}
